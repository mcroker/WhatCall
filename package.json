{
  "name": "whatcall",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "doc": "npx typedoc --out docs --entryPointStrategy Expand src  --exclude **/*.spec.ts --excludePrivate --excludeExternals --includeVersion",
    "uml": "tsuml2 --glob \"./src/**/!(*.d|*.spec).ts\" --outFile  ./docs/uml.svg",
    "sme": "ng build --source-map=true --named-chunks==true && source-map-explorer dist/whatcall/**/*.js --no-border-checks"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular-devkit/build-angular": "~20.2.2",
    "@angular/cdk": "~20.2.0",
    "@angular/cli": "~20.2.2",
    "@angular/common": "~20.2.2",
    "@angular/compiler": "~20.2.2",
    "@angular/compiler-cli": "~20.2.2",
    "@angular/core": "~20.2.2",
    "@angular/fire": "~20.0.1",
    "@angular/forms": "~20.2.2",
    "@angular/material": "~20.2.14",
    "@angular/platform-browser": "~20.2.2",
    "@angular/platform-browser-dynamic": "~20.2.2",
    "@angular/router": "~20.2.2",
    "@firebase-oss/ui-angular": "^7.0.2-beta",
    "@types/video.js": "^7.3.58",
    "chart.js": "^4.5.1",
    "firebase": "~11.10.0",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "video.js": "^8.23.4",
    "videojs-youtube": "^3.0.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "~20.2.0",
    "@angular/cli": "~20.2.0",
    "@angular/compiler-cli": "~20.2.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "jsdom": "^27.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "source-map-explorer": "^2.5.3",
    "testdouble": "^3.20.2",
    "typedoc": "^0.28.15",
    "typescript": "~5.9.2",
    "vitest": "^3.1.1"
  }
}
